rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {};
    }

    function isBanned() {
      let data = getUserData();
      return isSignedIn() && (
        data.get('isBanned', false) == true || 
        data.get('isBanned', 'false') == 'true'
      );
    }

    function isSuspended() {
      let data = getUserData();
      let suspendedUntil = data.get('suspendedUntil', request.time);
      return isSignedIn() && (
        (suspendedUntil is timestamp && suspendedUntil.toMillis() > request.time.toMillis()) ||
        (suspendedUntil is number && suspendedUntil > request.time.toMillis())
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.isSuperAdmin == true
      );
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.role in ['admin', 'moderator', 'super_admin'] ||
        request.auth.token.isAdmin == true ||
        getUserData().get('role', 'PLAYER') in ['admin', 'moderator', 'ADMIN', 'MODERATOR'] ||
        getUserData().get('isAdmin', false) == true
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role in ['admin', 'super_admin'] ||
        request.auth.token.role in ['ADMIN', 'SUPER_ADMIN'] ||
        request.auth.token.isAdmin == true ||
        getUserData().get('role', 'PLAYER') in ['admin', 'ADMIN'] ||
        getUserData().get('isAdmin', false) == true
      );
    }

    // Rate limiting helper
    function getRateLimitCount(key, intervalSeconds) {
      return (
        !exists(/databases/$(database)/documents/rate_limits/$(request.auth.uid + "_" + key)) ||
        get(/databases/$(database)/documents/rate_limits/$(request.auth.uid + "_" + key)).data.get('resetAt', 0) < request.time.toMillis()
      ) ? 0 : get(/databases/$(database)/documents/rate_limits/$(request.auth.uid + "_" + key)).data.get('count', 0);
    }

    // --- IDENTITY RESERVATION ---
    match /usernames/{username} {
      allow read: if false;
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /phones/{phone} {
      allow read: if false;
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/phones/$(phone));
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      // Allow any authenticated user to read user profiles (needed for leaderboard)
      allow read: if isSignedIn();
      
      allow create: if isOwner(userId);

      // FIX F-001 & F-005: Explicitly deny writes to sensitive fields + case-sensitive role normalization
      allow update: if isOwner(userId) && !isBanned() && !isSuspended()
        && (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['balanceCoins', 'totalWins', 'totalMatches', 'stats', 'isAdmin', 'role', 'isBanned', 
                   'testMode', 'suspendedUntil', 'banReason', 'intervention', 'phone', 'legalName', 
                   'bankCode', 'ssn', 'idVerified', 'verificationId', 'isIdentityLocked', 
                   'withdrawalCount', 'lifetimeDeposits', 'lifetimeWithdrawals'])
          || (
            // TACTICAL EXCEPTION: Allow setting these fields ONLY IF they don't exist yet (Race Condition Support)
            !resource.data.keys().hasAll(['balanceCoins', 'totalWins', 'totalMatches', 'referredBy'])
          )
        );
          
      match /notifications/{noteId} {
        allow read: if isOwner(userId) && !isBanned();
        allow write: if false; 
      }
      
      match /fcmTokens/{tokenId} {
        // Users write their own device tokens; server reads via Admin SDK
        allow create, update: if isOwner(userId) && !isBanned();
        allow delete: if isOwner(userId);
        allow read: if false;
      }
    }

    // --- MATCHES (LOBBY & PRIVATE) ---
    match /matches/{matchId} {
      
      allow read: if isSignedIn() && (
        resource.data.get('status', 'WAITING') in ['WAITING', 'READY', 'WAITING_FOR_OPPONENT', 'IN_PROGRESS', 'RESOLVING', 'DISPUTED', 'COMPLETED', 'CANCELLED'] || 
        resource.data.get('circuitId', null) != null || 
        resource.data.get('leagueId', null) != null ||
        request.auth.uid in resource.data.get('playerIds', []) ||
        resource.data.get('creatorId', '') == request.auth.uid ||
        isStaff() 
      );
      
      allow write: if false;
    }

    // --- MESSAGES (MATCH CHAT) ---
    match /matches/{matchId}/messages/{messageId} {
      function canAccessChat() {
        let matchDoc = get(/databases/$(database)/documents/matches/$(matchId));
        let matchData = matchDoc.data;
        let uid = request.auth.uid;
        
        return isSignedIn() && (
          isStaff() ||
          (
            !isBanned() && !isSuspended() &&
            (
              uid == matchData.get('creatorId', '') ||
              uid in matchData.get('playerIds', []) ||
              (matchData.get('isProtected', false) == false && matchData.get('status', 'WAITING') in ['WAITING', 'READY'])
            )
          )
        );
      }

      allow read: if isSignedIn() && canAccessChat();
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && canAccessChat()
        && get(/databases/$(database)/documents/matches/$(matchId)).data.get('status', 'WAITING') in ['WAITING', 'READY', 'IN_PROGRESS', 'RESOLVING', 'WAITING_FOR_OPPONENT', 'DISPUTED'];
    }

    // --- COMPETITION CHATS (WAR ROOM GLOBAL) ---
    match /competition_chats/{competitionId}/messages/{messageId} {
      allow read: if isSignedIn() && !isBanned();
      allow create: if isSignedIn() && !isBanned() && !isSuspended()
                    && request.resource.data.senderUid == request.auth.uid
                    && getRateLimitCount('created_chats', 86400) < 5;
    }

    // --- CHALLENGE INTEREST (WAITLIST) ---
    match /challenge_interest/{interestId} {
      allow read: if isSignedIn() && !isBanned();
      allow create: if isSignedIn() && !isBanned() && !isSuspended() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
    
    // --- QUEUES (Atomic Matchmaking) ---
    match /queues/{queueId} {
      allow read: if isSignedIn() && !isBanned();
      allow write: if false; 
    }

    // --- TRANSACTIONS (Order History) ---
    match /transactions/{docId} {
      allow read: if isSignedIn() && !isBanned() && (resource.data.uid == request.auth.uid || isStaff());
      allow write: if false; 
    }

    // --- WITHDRAWALS (Treasury Queue) ---
    match /withdrawals/{docId} {
      allow read: if isSignedIn() && !isBanned() && (resource.data.uid == request.auth.uid || isStaff());
      allow write: if false; 
    }

    // --- CIRCUITS (Multi-Stage Tournaments) ---
    match /circuits/{circuitId} {
      allow read: if true; // Publicly visible for tournament browsing
      allow write: if false; 
    }
    
    // --- PROMO EVENTS (Campaigns) ---
    match /promo_events/{promoId} {
      allow read: if true; // Publicly visible for marketing/landing page
      allow write: if false; // Managed by Server Actions
    }

    // --- LEAGUES (Legacy Tournament Format) ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // --- CONTACT MESSAGES ---
    match /contact_messages/{messageId} {
      allow read, update, delete: if isStaff();
      allow write: if false; // Creation is handled natively by Server Action bypass
    }

    // --- ADMIN AUDIT LOG ---
    match /admin_audit_log/{docId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // --- GLOBAL STATS ---
    match /stats/{statId} {
      allow read: if isSignedIn() && !isBanned() && (statId != 'platform_finances' || isAdmin());
      allow write: if false;
    }

    // --- SYSTEM CONFIG ---
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- SUPPORT TICKETS ---
    match /support_tickets/{ticketId} {
      // Users can read their own tickets; admins can read all tickets
      allow read: if isSignedIn() && !isBanned() && (
        resource.data.uid == request.auth.uid || 
        isAdmin()
      );
      
      // Users can create tickets (handled via server action, but allow for completeness)
      allow create: if isSignedIn() && !isBanned();
      
      // Users can update only their own tickets (limited fields); admins can update all
      allow update: if isSignedIn() && !isBanned() && !isSuspended() && (
        isAdmin() || (
          resource.data.uid == request.auth.uid && 
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'priority', 'adminAssigned', 'resolvedAt', 'closedAt', 'uid', 'ticketId', 'category', 'subject'])
        )
      );
      
      allow write: if false; // Prevent deletes
      
      // Messages sub-collection: all authenticated users in a ticket thread can read
      match /messages/{messageId} {
        allow read: if isSignedIn() && !isBanned() && (
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.uid == request.auth.uid ||
          isAdmin()
        );
        
        allow create: if isSignedIn() && !isBanned() && (
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.uid == request.auth.uid ||
          isAdmin()
        );
        
        allow write: if false; // Prevent updates/deletes to messages
      }
    }

    // FIX A-001: Admin approval queue for high-value balance adjustments
    match /admin_approval_queue/{requestId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() && isSuperAdmin();
      allow delete: if isSuperAdmin() && resource.data.status in ['approved', 'rejected', 'expired'];
    }

    // FIX M-005: Escrow for disputed match funds
    match /escrow_funds/{docId} {
      allow read: if isSignedIn() && !isBanned() && (
        resource.data.uid == request.auth.uid || 
        isAdmin()
      );
      allow write: if false; // Server-only writes via Admin SDK
    }

    // FIX R-002 & R-003: Rate limits for contact form and payment checks
    match /rate_limits/{limitId} {
      allow read: if false;
      allow write: if false; // Server-only via Admin SDK
    }

    // FIX F-003: Session binding for IP/UA validation
    match /sessions/{sessionId} {
      allow read: if false;
      allow write: if false; // Server-only via Admin SDK
    }
  }
}
