rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      // Use exists() check as a safe guard. get().data is only called if it exists.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {};
    }

    function isBanned() {
      return isSignedIn() && getUserData().get('isBanned', false) == true;
    }

    function isSuspended() {
      return isSignedIn() && (
        getUserData().get('suspendedUntil', request.time).toMillis() > request.time.toMillis()
      );
    }

    function isStaff() {
      return isSignedIn() && (
        getUserData().get('role', 'PLAYER') in ['ADMIN', 'MODERATOR'] || 
        getUserData().get('isAdmin', false) == true
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserData().get('role', 'PLAYER') == 'ADMIN' || 
        getUserData().get('isAdmin', false) == true
      );
    }

    // --- IDENTITY RESERVATION ---
    match /usernames/{username} {
      allow read: if true; 
      allow create: if isSignedIn() && !isBanned() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /phones/{phone} {
      allow read: if true; 
      allow create: if isSignedIn() && !isBanned() && !exists(/databases/$(database)/documents/phones/$(phone));
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read: if isSignedIn() && !isBanned();
      
      allow create: if isOwner(userId)
        && !('isAdmin' in request.resource.data)
        && !('role' in request.resource.data)
        && !('isBanned' in request.resource.data);

      allow update: if isOwner(userId) && !isBanned() && !isSuspended()
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['balanceCoins', 'totalWins', 'totalMatches', 'stats', 'isAdmin', 'role', 'isBanned', 'testMode', 'suspendedUntil', 'banReason']);
          
      match /notifications/{noteId} {
        allow read: if isOwner(userId) && !isBanned();
        allow write: if false; 
      }
    }

    // --- MATCHES (LOBBY & PRIVATE) ---
    match /matches/{matchId} {
      allow read: if isSignedIn() && !isBanned() && (
        resource.data.get('status', 'WAITING') in ['WAITING', 'READY', 'WAITING_FOR_OPPONENT'] || 
        request.auth.uid in resource.data.playerIds ||
        resource.data.creatorId == request.auth.uid ||
        resource.data.get('leagueId', null) != null ||
        isStaff() 
      );
      
      allow write: if false;
    }

    // --- MESSAGES (MATCH CHAT) ---
    match /matches/{matchId}/messages/{messageId} {
      function canAccessChat() {
        return isSignedIn() && (
          (request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.playerIds && !isBanned() && !isSuspended()) || 
          isStaff()
        );
      }

      allow read: if isSignedIn() && canAccessChat();
      allow create: if isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && canAccessChat();
    }

    // --- CHALLENGE INTEREST (WAITLIST) ---
    match /challenge_interest/{interestId} {
      allow read: if isSignedIn() && !isBanned();
      allow create: if isSignedIn() && !isBanned() && !isSuspended() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
    
    // --- LEAGUES ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn() && !isBanned();
      allow write: if false; 
    }

    // --- QUEUES (Atomic Matchmaking) ---
    match /queues/{queueId} {
      allow read: if isSignedIn() && !isBanned();
      allow write: if false; 
    }

    // --- TRANSACTIONS (Order History) ---
    match /transactions/{docId} {
      allow read: if isSignedIn() && !isBanned() && (resource.data.uid == request.auth.uid || isStaff());
      allow write: if false; 
    }

    // --- WITHDRAWALS (Treasury Queue) ---
    match /withdrawals/{docId} {
      allow read: if isSignedIn() && !isBanned() && (resource.data.uid == request.auth.uid || isStaff());
      allow write: if false; 
    }

    // --- ADMIN AUDIT LOG ---
    match /admin_audit_log/{docId} {
      allow read: if isAdmin(); 
      allow write: if false;
    }

    // --- GLOBAL STATS ---
    match /stats/{statId} {
      allow read: if isSignedIn() && !isBanned() && (statId != 'platform_finances' || isAdmin());
      allow write: if false;
    }
  }
}
